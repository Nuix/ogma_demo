# Backend Configuration
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://witness:password@localhost:5432/witness_board
DB_USER=witness
DB_PASSWORD=witnesspass
DB_NAME=witness_board

# Claude via AWS Bedrock (no direct Anthropic API key needed)
AWS_ACCESS_KEY_ID=your-key-id
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
ANTHROPIC_MODEL=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# Application Settings
TARGET_NAME=Your Name Here
LAST_SEEN_DATE=2026-06-01
CASE_START_NUMBER=1000

# GitHub sightings feed
POLL_URL=https://raw.githubusercontent.com/your-org/your-repo/main/sightings.json
POLL_INTERVAL_MS=300000

# Security
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=10

LOG_LEVEL=info
